# CCC Kaggle Agentic Workspace — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ─── API Keys ─────────────────────────────────────────────────────────────────

# Anthropic (required for Claude Code and Aider with Anthropic provider)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenAI (optional — for Codex CLI and OpenCode with OpenAI provider)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ─── VPS Configuration ────────────────────────────────────────────────────────

# BinaryLane VPS IP or hostname
VPS_HOST=YOUR_VPS_IP

# SSH user for VPS access (created by vps/create-users.sh)
VPS_USER=deploy

# SSH key path (on your local machine)
VPS_SSH_KEY=~/.ssh/vps_ed25519

# ─── code-server ──────────────────────────────────────────────────────────────

# Password for code-server web login
# Generate with: openssl rand -base64 24
CODE_SERVER_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Port code-server listens on (internal, not exposed publicly)
CODE_SERVER_PORT=8080

# ─── Cloudflare ───────────────────────────────────────────────────────────────

# Tunnel token from Cloudflare Zero Trust dashboard
# Zero Trust → Tunnels → Your tunnel → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# Your coding subdomain
CODING_DOMAIN=coding.cairnscustomcomputers.cloud

# ─── Kaggle Tunnel ────────────────────────────────────────────────────────────

# Path to SSH private key for kaggle-gpu → VPS tunnel
# This key must NOT be your main VPS key — use a dedicated keypair
KAGGLE_TUNNEL_KEY_PATH=~/.ssh/kaggle_tunnel_ed25519

# Port that the Kaggle LLM server will be forwarded to on the VPS
KAGGLE_TUNNEL_PORT=8081

# ─── Local LLM (Kaggle GPU) ───────────────────────────────────────────────────

# Base URL for local LLM server (when Kaggle tunnel is active)
LLM_BASE_URL=http://localhost:8081/v1

# Dummy API key for local LLM (most servers accept any value)
LLM_API_KEY=local

# Model name as reported by the local server
LLM_MODEL=qwen2.5-coder-7b-instruct

# ─── Active Provider (managed by switch_provider.sh) ─────────────────────────

# Options: anthropic, openai, local
ACTIVE_PROVIDER=anthropic

# Model to use with the active provider
ACTIVE_MODEL=claude-sonnet-4-6

# ─── Alerts (optional) ────────────────────────────────────────────────────────

# Webhook URL for session watchdog alerts (Discord, Slack, ntfy.sh, etc.)
# Leave blank to disable alerts
ALERT_WEBHOOK_URL=

# ntfy.sh topic (alternative to generic webhook)
NTFY_TOPIC=

# ─── Workspace ────────────────────────────────────────────────────────────────

# Base directory for workspace on VPS
WORKSPACE_DIR=/opt/coding-workspace

# GitHub org/user that owns this repo
GITHUB_ORG=YOUR_GITHUB_USERNAME
