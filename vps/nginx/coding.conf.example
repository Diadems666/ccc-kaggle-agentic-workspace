# nginx reverse proxy for code-server (OPTIONAL)
# Only needed if you're NOT using Cloudflare Tunnel and want direct HTTPS.
# With Cloudflare Tunnel, nginx is not required.

server {
    listen 80;
    server_name coding.cairnscustomcomputers.cloud;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name coding.cairnscustomcomputers.cloud;

    ssl_certificate     /etc/letsencrypt/live/coding.cairnscustomcomputers.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/coding.cairnscustomcomputers.cloud/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options    nosniff always;
    add_header X-Frame-Options           SAMEORIGIN always;

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # WebSocket support (required for code-server)
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection upgrade;
        proxy_read_timeout 86400;
    }
}
